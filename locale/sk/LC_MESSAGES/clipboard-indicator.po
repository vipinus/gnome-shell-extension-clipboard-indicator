#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Po výbere presunúť položku hore"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Zachovať vybranú položku po vymazaní"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Zobraziť tlačidlá vloženia"

