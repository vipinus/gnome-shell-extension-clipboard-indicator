#: extension.js:113
msgid "Text will be here"
msgstr "Text bude tu"

#: extension.js:187
msgid "Type here to search..."
msgstr "Zadajte text pre vyhľadávanie..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Súkromný režim"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Vymazať históriu"

#: extension.js:315
msgid "Settings"
msgstr "Nastavenia"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Schránka je prázdna"

#: extension.js:626
msgid "Clear all?"
msgstr "Vymazať všetko?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Naozaj chcete odstrániť všetky položky schránky?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Túto operáciu nie je možné vrátiť."

#: extension.js:630
msgid "Clear"
msgstr "Vymazať"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Zrušiť"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "História schránky bola vymazaná"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "História bola vymazaná automaticky"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Skopírované do schránky"

#: prefs.js:31
msgid "History Size"
msgstr "Veľkosť histórie"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Veľkosť náhľadu (znaky)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Max. veľkosť súboru vyrovnávacej pamäte (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Počet znakov v hornej lište"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Čo zobraziť v hornej lište"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Odstrániť šípku dole v hornej lište"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Ukladať len pripnuté položky"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Zobraziť upozornenie pri kopírovaní"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Zobraziť upozornenie pri prepínaní"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Zobraziť potvrdenie pri mazaní"

#: prefs.js:92
msgid "Remove whitespace around text"
