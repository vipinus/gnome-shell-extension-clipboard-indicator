#: prefs.js:127
msgid "Excluded Apps"
msgstr "Vylúčené aplikácie"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr "Skopírovaný obsah nebude uložený, keď sú tieto aplikácie aktívne"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Vyhľadávanie rozlišujúce veľkosť písmen"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Hľadanie pomocou regulárnych výrazov"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Pravidelne mazať históriu schránky"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Interval mazania histórie (minúty)"

#: prefs.js:172
msgid "UI"
msgstr "Rozhranie"

#: prefs.js:173
msgid "Behavior"
msgstr "Správanie"

#: prefs.js:174
msgid "Exclusion"
msgstr "Vylúčenie"

#: prefs.js:175
msgid "Limits"
msgstr "Limity"

#: prefs.js:176
msgid "Topbar"
msgstr "Horná lišta"

#: prefs.js:177
msgid "Notifications"
msgstr "Upozornenia"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Skratky"

#: prefs.js:179
msgid "Search"
msgstr "Vyhľadávanie"

#: prefs.js:244
msgid "Icon"
msgstr "Ikona"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Obsah schránky"

#: prefs.js:246
msgid "Both"
msgstr "Oboje"

#: prefs.js:247
msgid "Neither"
msgstr "Nič"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Prepnúť ponuku"

#: prefs.js:260
msgid "Previous entry"
