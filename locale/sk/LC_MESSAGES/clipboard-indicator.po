#: prefs.js:261
msgid "Next entry"
msgstr "Nasledujúca položka"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Povoliť skratky"

#: prefs.js:291
msgid "Disabled"
msgstr "Zakázané"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Zadajte skratku"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Názov triedy okna, napr. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Vybrať z nainštalovaných aplikácií"

#: prefs.js:416
msgid "Search applications..."
msgstr "Hľadať aplikácie..."

