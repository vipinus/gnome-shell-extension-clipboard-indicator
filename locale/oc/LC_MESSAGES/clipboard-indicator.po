#: extension.js:113
msgid "Text will be here"
msgstr "Lo tèxte serà aicí"

#: extension.js:187
msgid "Type here to search..."
msgstr "Picatz aicí per recercar..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Mòde privat"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Escafar l'istoric"

#: extension.js:315
msgid "Settings"
msgstr "Paramètres"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Lo quichapapièrs es void"

#: extension.js:626
msgid "Clear all?"
msgstr "Tot escafar ?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Volètz vertadièrament suprimir totes los elements del quichapapièrs ?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Aquesta operacion pòt pas èsser anullada."

#: extension.js:630
msgid "Clear"
msgstr "Escafar"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Anullar"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Istoric del quichapapièrs escafat"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Istoric escafat automaticament"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Copiat dins lo quichapapièrs"

#: prefs.js:31
msgid "History Size"
msgstr "Talha de l'istoric"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Talha de l'apercebut (caractèrs)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Talha max. del fichièr cache (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Nombre de caractèrs dins la barra del naut"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Çò qu'afichar dins la barra del naut"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Suprimir la sageta cap aval dins la barra del naut"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Metre en cache sonque los elements penjats"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Mostrar notificacion a la còpia"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Mostrar notificacion al cicle"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Mostrar confirmacion al escafament"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Suprimir los espacis a l'entorn del tèxte"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Desplaçar amont aprèp seleccion"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Servar l'entrada seleccionada aprèp escafament"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Mostrar los botons de pegada"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "Apondís un boton de pegada a cada entrada"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Plaçar la seccion penjada en bas"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Necessita lo reaviada de l'extension"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Escafar l'istoric al reaviada"

#: prefs.js:118
msgid "Paste on select"
msgstr "Pegar a la seleccion"

#: prefs.js:122
msgid "Cache images"
msgstr "Metre las imatges en cache"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Aplicacions exclusas"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Lo contengut copiat serà pas enregistrat quand aquestas aplicacions son "
"activas"

