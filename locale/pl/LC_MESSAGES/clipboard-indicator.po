#: extension.js:113
msgid "Text will be here"
msgstr "Tekst pojawi się tutaj"

#: extension.js:187
msgid "Type here to search..."
msgstr "Wpisz tu, aby wyszukać..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Tryb prywatny"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Wyczyść historię"

#: extension.js:315
msgid "Settings"
msgstr "Ustawienia"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Schowek jest pusty"

#: extension.js:626
msgid "Clear all?"
msgstr "Wyczyścić wszystko?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Czy na pewno chcesz usunąć wszystkie elementy schowka?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Tej operacji nie można cofnąć."

#: extension.js:630
msgid "Clear"
msgstr "Wyczyść"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Anuluj"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Historia schowka wyczyszczona"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Historia wyczyszczona automatycznie"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Skopiowano do schowka"

#: prefs.js:31
msgid "History Size"
msgstr "Rozmiar historii"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Rozmiar podglądu (znaki)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Maks. rozmiar pliku bufora (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Liczba znaków w górnym pasku"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Co pokazać na górnym pasku"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Usuń strzałkę w dół z górnego paska"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Buforuj tylko przypięte elementy"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Pokaż powiadomienie przy kopiowaniu"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Pokaż powiadomienie przy przełączaniu"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Pokaż potwierdzenie przy czyszczeniu"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Usuń białe znaki wokół tekstu"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Przenieś element na górę po wybraniu"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Zachowaj wybrany wpis po wyczyszczeniu"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Pokaż przyciski wklejania"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "Dodaje przycisk wklejania do każdego wpisu"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Umieść sekcję przypiętą na dole"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Wymaga restartu rozszerzenia"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Czyść historię przy restarcie systemu"

#: prefs.js:118
msgid "Paste on select"
msgstr "Wklej przy wyborze"

#: prefs.js:122
msgid "Cache images"
msgstr "Buforuj obrazy"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Wykluczone aplikacje"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Skopiowana zawartość nie zostanie zapisana, gdy te aplikacje są aktywne"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Wyszukiwanie z uwzględnieniem wielkości liter"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Wyrażenia regularne w wyszukiwaniu"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Czyść historię schowka okresowo"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Interwał czyszczenia (w minutach)"

#: prefs.js:172
msgid "UI"
msgstr "UI"

#: prefs.js:173
msgid "Behavior"
msgstr "Zachowanie"

#: prefs.js:174
msgid "Exclusion"
msgstr "Wykluczenie"

#: prefs.js:175
msgid "Limits"
msgstr "Limity"

#: prefs.js:176
msgid "Topbar"
msgstr "Górny pasek"

#: prefs.js:177
msgid "Notifications"
msgstr "Powiadomienia"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Skróty"

#: prefs.js:179
msgid "Search"
msgstr "Wyszukiwanie"

#: prefs.js:244
msgid "Icon"
msgstr "Ikona"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Zawartość schowka"

#: prefs.js:246
msgid "Both"
msgstr "Oba"

#: prefs.js:247
msgid "Neither"
msgstr "Żadne"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Przełącz menu"

#: prefs.js:260
msgid "Previous entry"
msgstr "Poprzedni wpis"

#: prefs.js:261
msgid "Next entry"
msgstr "Następny wpis"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Włącz skróty"

#: prefs.js:291
msgid "Disabled"
msgstr "Wyłączone"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Wpisz skrót"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Nazwa klasy okna, np. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Wybierz z zainstalowanych aplikacji"

#: prefs.js:416
msgid "Search applications..."
msgstr "Wyszukaj aplikacje..."

#~ msgid "Add button to paste an entry"
#~ msgstr "Dodaj przycisk, aby wkleić wpis"

#~ msgid ""
#~ "If true, adds another button to each menu entry that lets you immediately "
#~ "paste it"
#~ msgstr ""
#~ "Jeśli włączone, dodaje przycisk do każdego wpisu menu, który pozwala na "
#~ "natychmiastowe wklejenie"

#~ msgid "Display the pinned section on the bottom"
#~ msgstr "Wyświetlaj przypiętą sekcję na dole"

#~ msgid "If true, places the \"pinned\" section on the bottom"
#~ msgstr "Jeśli włączone, umieszcza sekcję „przypięte” na dole"

#~ msgid "Enable the deletion of clipboard items from your history"
#~ msgstr "Włącz usuwanie elementów schowka z historii"

#~ msgid ""
#~ "If true, displays 'delete' buttons on each item, and a 'Clear History' "
#~ "option"
#~ msgstr ""
#~ "Jeśli włączone, wyświetla przyciski „Usuń” przy każdym elemencie oraz opcję "
#~ "„Wyczyść historię”"

#~ msgid "The number of items to save in history"
#~ msgstr "Liczba elementów do zapisania w historii"

#~ msgid "What to display in top bar"
#~ msgstr "Wyświetlanie na panelu"

#~ msgid "Clear clipboard history on every system reboot."
#~ msgstr "Wyczyść historię schowka przy każdym ponownym uruchomieniu systemu."

#~ msgid "Amount of visible characters for clipboard items"
#~ msgstr "Liczba widocznych znaków dla elementów schowka"

#~ msgid ""
#~ "The number of characters to display for every clipboard item in the history "
#~ "menu"
#~ msgstr ""
#~ "Liczba znaków do wyświetlenia dla każdego elementu schowka w menu historii"

#~ msgid "Amount of visible characters in topbar"
#~ msgstr "Liczba widocznych znaków na panelu"

#~ msgid ""
#~ "The number of characters to display for current clipboard item in the topbar"
#~ msgstr ""
#~ "Liczba znaków do wyświetlenia dla bieżącego elementu schowka na górnym pasku"

#~ msgid "The allowed size for the registry cache file in MB"
#~ msgstr "Dozwolony rozmiar pliku pamięci podręcznej rejestru w MB"

#~ msgid ""
#~ "If the cache overflows this limit, the file will be overriden. High limit "
#~ "might cause slowness of shell startup."
#~ msgstr ""
#~ "Jeśli pamięć podręczna przekroczy ten limit, plik zostanie nadpisany. Wysoki"
#~ " limit może spowodować spowolnienie uruchamiania powłoki GNOME."

#~ msgid "Disable the registry cache file for favorites and use memory only"
#~ msgstr ""
#~ "Wyłącz plik pamięci podręcznej rejestru dla ulubionych i używaj tylko "
#~ "pamięci"

#~ msgid ""
#~ "Contents which are not favorites are not stored and retrieved from a cache "
#~ "(registry.txt) file. This can avoid writing passwords to a plaintext file, "
#~ "but at the cost of persistant history. Your clipboard history, except "
#~ "favorite items, is lost after a gnome-shell session ends or the extension is"
#~ " reloaded."
#~ msgstr ""
#~ "Zawartość, która nie jest oznaczona jako ulubiona, nie jest przechowywana i "
#~ "pobierana z pliku pamięci podręcznej (registry.txt). Może to zapobiec "
#~ "zapisywaniu haseł do pliku w postaci zwykłego tekstu, ale kosztem trwałej "
#~ "historii. Historia schowka, z wyjątkiem ulubionych elementów, jest tracona "
#~ "po zakończeniu sesji powłoki GNOME lub ponownym załadowaniu rozszerzenia."

#~ msgid "Show notification on copy to clipboard"
#~ msgstr "Pokaż powiadomienie po skopiowaniu do schowka"

#~ msgid "If true, a notification is shown when content is copied to clipboard."
#~ msgstr ""
#~ "Jeśli włączone, wyświetlane jest powiadomienie, gdy zawartość zostanie "
#~ "skopiowana do schowka."

#~ msgid "Show notification when cycling through the entries with hotkeys"
#~ msgstr "Pokaż powiadomienie przy wykorzystaniu skrótu klawiszowego"

#~ msgid ""
#~ "If true, a notification is shown when cycling through the clipboard entries "
#~ "using hotkeys."
#~ msgstr ""
#~ "Jeśli włączone, powiadomienie jest pokazane po wykorzystaniu skrótów "
#~ "klawiszowych wpisów schowka."

#~ msgid "Show confirmation dialog on Clear History"
#~ msgstr "Pokaż okno dialogowe z potwierdzeniem po kliknięciu Wyczyść historię"

#~ msgid ""
#~ "If true, a confirmation dialog is shown when attempting to Clear History."
#~ msgstr ""
#~ "Jeśli włączone, wyświetlane jest okno dialogowe z potwierdzeniem podczas "
#~ "próby wyczyszczenia historii."

#~ msgid "If true, white spaces around text will be removed."
#~ msgstr "Jeśli włączone, białe znaki wokół tekstu zostaną usunięte."

#~ msgid "Move items to the top of the list when selected."
#~ msgstr "Przenieś wybrane elementy na początek listy."

#~ msgid "If true, move items to the top of the list when it is selected."
#~ msgstr "Jeśli włączone, przenosi wybrane elementy na początek listy."

#~ msgid "Keep selected item on clear"
#~ msgstr "Zachowaj wybrany element przy czyszczeniu"

#~ msgid ""
#~ "Whether to keep the currently selected entry in the clipboard after clearing"
#~ " the history"
#~ msgstr ""
#~ "Zachowanie aktualnie wybranego wpisu w schowku po wyczyszczeniu historii"

#~ msgid "Enable the keyboard shortcuts"
#~ msgstr "Włącz skróty klawiszowe"

#~ msgid ""
#~ "If true, user can delete and cycle through the history with keyboard "
#~ "shortcuts"
#~ msgstr ""
#~ "Jeśli włączone, użytkownik może usuwać i przeglądać historię za pomocą "
#~ "skrótów klawiaturowych"

#~ msgid "Key to clear the history"
#~ msgstr "Klawisz do czyszczenia historii"

#~ msgid "Key to cycle to the previous entry in the clipboard"
#~ msgstr "Skrót do przechodzenia do poprzedniego wpisu w schowku"

#~ msgid "Key to cycle to the next entry in the clipboard"
#~ msgstr "Skrót do przechodzenia do następnego wpisu w schowku"

#~ msgid "Key to toggle the clipboard menu"
#~ msgstr "Skrót do wyświetlania schowka"

#~ msgid "Toggle \"Private Mode\""
#~ msgstr "Przełącz \"Tryb prywatny\""

#~ msgid "Key to toggle the private mode"
#~ msgstr "Skrót do włączania trybu prywatnego"

#~ msgid "Allow caching images to disk"
#~ msgstr "Zezwalaj na buforowanie obrazów na dysku"

#~ msgid "A list of applications that are excluded from clipboard history."
#~ msgstr "Lista aplikacji, które są wykluczone z historii schowka."
