#: extension.js:113
msgid "Text will be here"
msgstr "Το κείμενο θα εμφανιστεί εδώ"

#: extension.js:187
msgid "Type here to search..."
msgstr "Πληκτρολογήστε εδώ για αναζήτηση..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Ιδιωτική λειτουργία"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Εκκαθάριση ιστορικού"

#: extension.js:315
msgid "Settings"
msgstr "Ρυθμίσεις"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Το πρόχειρο είναι κενό"

#: extension.js:626
msgid "Clear all?"
msgstr "Εκκαθάριση όλων;"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Είστε βέβαιοι ότι θέλετε να διαγράψετε όλα τα στοιχεία;"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Αυτή η ενέργεια δεν μπορεί να αναιρεθεί."

#: extension.js:630
msgid "Clear"
msgstr "Εκκαθάριση"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Ακύρωση"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Το ιστορικό εκκαθαρίστηκε"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Το ιστορικό εκκαθαρίστηκε αυτόματα"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Αντιγράφηκε στο πρόχειρο"

#: prefs.js:31
msgid "History Size"
msgstr "Μέγεθος ιστορικού"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Μέγεθος προεπισκόπησης (χαρακτήρες)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Μέγιστο μέγεθος cache (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Αριθμός χαρακτήρων στην επάνω μπάρα"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Τι να εμφανίζεται στην επάνω μπάρα"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Αφαίρεση κάτω βέλους από την επάνω μπάρα"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Αποθήκευση μόνο καρφιτσωμένων στοιχείων"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Ειδοποίηση κατά την αντιγραφή"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Ειδοποίηση κατά την εναλλαγή"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Επιβεβαίωση κατά την εκκαθάριση"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Αφαίρεση κενών γύρω από το κείμενο"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Μετακίνηση στην κορυφή μετά την επιλογή"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Διατήρηση επιλεγμένης καταχώρησης μετά την εκκαθάριση"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Εμφάνιση κουμπιών επικόλλησης"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "Προσθέτει ένα κουμπί επικόλλησης σε κάθε καταχώρηση"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Καρφιτσωμένη ενότητα στο κάτω μέρος"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Απαιτεί επανεκκίνηση της επέκτασης"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Εκκαθάριση ιστορικού στην επανεκκίνηση"

#: prefs.js:118
msgid "Paste on select"
msgstr "Επικόλληση κατά την επιλογή"

#: prefs.js:122
msgid "Cache images"
msgstr "Προσωρινή αποθήκευση εικόνων"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Εξαιρούμενες εφαρμογές"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"Το περιεχόμενο δεν θα αποθηκεύεται όταν αυτές οι εφαρμογές είναι ενεργές"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Αναζήτηση με διάκριση πεζών-κεφαλαίων"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Αντιστοίχιση κανονικών εκφράσεων"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Εκκαθάριση ιστορικού περιοδικά"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Διάστημα εκκαθάρισης (σε λεπτά)"

#: prefs.js:172
msgid "UI"
msgstr "Διεπαφή"

#: prefs.js:173
msgid "Behavior"
msgstr "Συμπεριφορά"

#: prefs.js:174
msgid "Exclusion"
msgstr "Εξαίρεση"

#: prefs.js:175
msgid "Limits"
msgstr "Όρια"

#: prefs.js:176
msgid "Topbar"
msgstr "Επάνω μπάρα"

#: prefs.js:177
msgid "Notifications"
msgstr "Ειδοποιήσεις"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Συντομεύσεις"

#: prefs.js:179
msgid "Search"
msgstr "Αναζήτηση"

#: prefs.js:244
msgid "Icon"
msgstr "Εικονίδιο"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Περιεχόμενο προχείρου"

#: prefs.js:246
msgid "Both"
msgstr "Και τα δύο"

#: prefs.js:247
msgid "Neither"
msgstr "Κανένα"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Εναλλαγή μενού"

#: prefs.js:260
msgid "Previous entry"
msgstr "Προηγούμενη καταχώρηση"

#: prefs.js:261
msgid "Next entry"
msgstr "Επόμενη καταχώρηση"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Ενεργοποίηση συντομεύσεων"

#: prefs.js:291
msgid "Disabled"
msgstr "Απενεργοποιημένο"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Εισάγετε συντόμευση"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Όνομα κλάσης παραθύρου, π.χ. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Επιλογή από εγκατεστημένες εφαρμογές"

#: prefs.js:416
msgid "Search applications..."
msgstr "Αναζήτηση εφαρμογών..."

#~ msgid "Refresh Interval (ms)"
#~ msgstr "Διάστημα επαναφόρτωσης (ms)"
