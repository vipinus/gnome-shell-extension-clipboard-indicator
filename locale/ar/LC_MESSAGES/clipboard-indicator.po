#: extension.js:113
msgid "Text will be here"
msgstr "النص سيظهر هنا"

#: extension.js:187
msgid "Type here to search..."
msgstr "اكتب هنا للبحث..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "الوضع الخاص"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "مسح السجل"

#: extension.js:315
msgid "Settings"
msgstr "الإعدادات"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "الحافظة فارغة"

#: extension.js:626
msgid "Clear all?"
msgstr "مسح الكل؟"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "هل أنت متأكد من حذف كل عناصر الحافظة؟"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "لا يمكن التراجع عن هذه العملية."

#: extension.js:630
msgid "Clear"
msgstr "مسح"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "إلغاء"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "تم مسح سجل الحافظة"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "تم مسح سجل الحافظة تلقائيًا"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "نُسخ إلى الحافظة"

#: prefs.js:31
msgid "History Size"
msgstr "حجم السجل"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "حجم المعاينة (أحرف)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "أقصى حجم لملف التخزين (ميغابايت)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "عدد الأحرف في الشريط العلوي"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "ما يظهر في الشريط العلوي"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "إزالة السهم لأسفل في الشريط العلوي"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "تخزين العناصر المثبتة فقط"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "إظهار إشعار عند النسخ"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "إظهار إشعار عند التنقل"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "إظهار تأكيد عند مسح السجل"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "إزالة المسافات حول النص"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "نقل العنصر إلى الأعلى بعد التحديد"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "احتفظ بالمدخل المحدد بعد مسح السجل"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "إظهار أزرار اللصق"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "يضيف زر لصق لكل مدخل يتيح لك لصقه مباشرة"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "ضع القسم المثبت في الأسفل"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "يتطلب إعادة تشغيل الإضافة"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "مسح سجل الحافظة عند إعادة تشغيل النظام"

#: prefs.js:118
msgid "Paste on select"
msgstr "لصق عند التحديد"

#: prefs.js:122
msgid "Cache images"
msgstr "تخزين الصور مؤقتًا"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "التطبيقات المستثناة"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr "لن يتم حفظ المحتوى المنسوخ عندما تكون هذه التطبيقات نشطة"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "بحث حساس لحالة الأحرف"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "مطابقة التعبير المنتظم في البحث"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "مسح سجل الحافظة دوريًا"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "فترة مسح السجل (بالدقائق)"

#: prefs.js:172
msgid "UI"
msgstr "الواجهة"

#: prefs.js:173
msgid "Behavior"
msgstr "السلوك"

#: prefs.js:174
msgid "Exclusion"
msgstr "الاستثناء"

#: prefs.js:175
msgid "Limits"
msgstr "الحدود"

#: prefs.js:176
msgid "Topbar"
msgstr "الشريط العلوي"

#: prefs.js:177
msgid "Notifications"
msgstr "الإشعارات"

#: prefs.js:178
msgid "Shortcuts"
msgstr "الاختصارات"

#: prefs.js:179
msgid "Search"
msgstr "بحث"

#: prefs.js:244
msgid "Icon"
msgstr "أيقونة"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "محتوى الحافظة"

#: prefs.js:246
msgid "Both"
msgstr "كلاهما"

#: prefs.js:247
msgid "Neither"
msgstr "لا شيء"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "تبديل القائمة"

#: prefs.js:260
msgid "Previous entry"
msgstr "المدخل السابق"

#: prefs.js:261
msgid "Next entry"
msgstr "المدخل التالي"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "تفعيل الاختصارات"

#: prefs.js:291
msgid "Disabled"
msgstr "معطل"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "أدخل اختصارًا"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "اسم فئة النافذة، مثل \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "اختر من التطبيقات المثبتة"

#: prefs.js:416
msgid "Search applications..."
msgstr "بحث التطبيقات..."

#~ msgid "Refresh Interval (ms)"
#~ msgstr "فترة التحديث بالمللي ثانية"

#~ msgid "Disable cache file"
#~ msgstr "إلغاء ملف ذاكرة التخزين المؤقت"
