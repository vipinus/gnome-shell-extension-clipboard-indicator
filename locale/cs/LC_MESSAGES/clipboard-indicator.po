#: extension.js:113
msgid "Text will be here"
msgstr "Zde bude text"

#: extension.js:187
msgid "Type here to search..."
msgstr "Pro hledání zadejte text..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Soukromý režim"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Vymazat historii"

#: extension.js:315
msgid "Settings"
msgstr "Nastavení"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Schránka je prázdná"

#: extension.js:626
msgid "Clear all?"
msgstr "Vymazat vše?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Opravdu chcete smazat všechny položky schránky?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Tuto operaci nelze vrátit zpět."

#: extension.js:630
msgid "Clear"
msgstr "Vymazat"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Zrušit"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Historie schránky vymazána"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Historie schránky byla automaticky vymazána"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Zkopírováno do schránky"

#: prefs.js:31
msgid "History Size"
msgstr "Velikost historie"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Velikost náhledu (znaky)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Max. velikost souboru mezipaměti (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Počet znaků v horní liště"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Co zobrazit v horní liště"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Odstranit šipku dolů v horní liště"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Ukládat pouze připnuté položky"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Zobrazit oznámení při kopírování"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Zobrazit oznámení při procházení"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Zobrazit potvrzení při vymazání historie"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Odstranit mezery kolem textu"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Po výběru přesunout položku nahoru"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Zachovat vybranou položku po vymazání historie"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Zobrazit tlačítka vložení"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "Přidá tlačítko vložení ke každé položce, které ji vloží přímo"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Umístit připnutou sekci dolů"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Vyžaduje restart rozšíření"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Vymazat historii při restartu systému"

#: prefs.js:118
msgid "Paste on select"
msgstr "Vložit při výběru"

#: prefs.js:122
msgid "Cache images"
msgstr "Ukládat obrázky do mezipaměti"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Vyloučené aplikace"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr "Zkopírovaný obsah nebude uložen, když jsou tyto aplikace aktivní"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Vyhledávání s rozlišením velikosti písmen"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Hledání pomocí regulárních výrazů"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Vymazat historii schránky v intervalu"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Interval mazání historie (v minutách)"

#: prefs.js:172
msgid "UI"
msgstr "Rozhraní"

#: prefs.js:173
msgid "Behavior"
msgstr "Chování"

#: prefs.js:174
msgid "Exclusion"
msgstr "Vyloučení"

#: prefs.js:175
msgid "Limits"
msgstr "Limity"

#: prefs.js:176
msgid "Topbar"
msgstr "Horní lišta"

#: prefs.js:177
msgid "Notifications"
msgstr "Oznámení"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Klávesové zkratky"

#: prefs.js:179
msgid "Search"
msgstr "Hledat"

#: prefs.js:244
msgid "Icon"
msgstr "Ikona"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Obsah schránky"

#: prefs.js:246
msgid "Both"
msgstr "Obojí"

#: prefs.js:247
msgid "Neither"
msgstr "Nic"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Přepnout nabídku"

#: prefs.js:260
msgid "Previous entry"
msgstr "Předchozí položka"

#: prefs.js:261
msgid "Next entry"
msgstr "Další položka"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Povolit klávesové zkratky"

#: prefs.js:291
msgid "Disabled"
msgstr "Zakázáno"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Zadejte zkratku"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Název třídy okna, např. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Vybrat z nainstalovaných aplikací"

#: prefs.js:416
msgid "Search applications..."
msgstr "Hledat aplikace..."

