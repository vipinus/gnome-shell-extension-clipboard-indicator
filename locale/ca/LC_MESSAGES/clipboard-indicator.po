#: extension.js:113
msgid "Text will be here"
msgstr "El text apareixerà aquí"

#: extension.js:187
msgid "Type here to search..."
msgstr "Escriviu aquí per cercar..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Mode privat"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Esborra l'historial"

#: extension.js:315
msgid "Settings"
msgstr "Configuració"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "El porta-retalls està buit"

#: extension.js:626
msgid "Clear all?"
msgstr "Esborrar-ho tot?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Esteu segur que voleu eliminar tots els elements del porta-retalls?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Aquesta operació no es pot desfer."

#: extension.js:630
msgid "Clear"
msgstr "Esborra"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Cancel·la"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "S'ha esborrat l'historial del porta-retalls"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Historial del porta-retalls esborrat automàticament"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Copiat al porta-retalls"

#: prefs.js:31
msgid "History Size"
msgstr "Mida de l'historial"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Mida de la previsualització (caràcters)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Mida màx. del fitxer de memòria cau (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Nombre de caràcters a la barra superior"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Què mostrar a la barra superior"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Treu la fletxa avall de la barra superior"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Memòria cau només d'elements fixats"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Mostra notificació en copiar"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Mostra notificació en canviar"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Mostra confirmació en esborrar l'historial"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Elimina els espais al voltant del text"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Mou l'element a dalt després de seleccionar-lo"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Mantén l'entrada seleccionada després d'esborrar l'historial"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Mostra els botons d'enganxar"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr ""
"Afegeix un botó d'enganxar a cada entrada que permet enganxar-la directament"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Col·loca la secció fixada a baix"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Requereix reiniciar l'extensió"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Esborrar l'historial en reiniciar el sistema"

#: prefs.js:118
msgid "Paste on select"
msgstr "Enganxa en seleccionar"

#: prefs.js:122
msgid "Cache images"
msgstr "Memòria cau d'imatges"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Aplicacions excloses"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr ""
"El contingut copiat no es desarà mentre aquestes aplicacions estiguin "
"actives"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Cerca distingint majúscules i minúscules"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Coincidència d'expressions regulars en la cerca"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Esborrar l'historial periòdicament"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Interval d'esborrat (en minuts)"

#: prefs.js:172
msgid "UI"
msgstr "Interfície"

#: prefs.js:173
msgid "Behavior"
msgstr "Comportament"

#: prefs.js:174
msgid "Exclusion"
msgstr "Exclusió"

#: prefs.js:175
msgid "Limits"
msgstr "Límits"

#: prefs.js:176
msgid "Topbar"
msgstr "Barra superior"

#: prefs.js:177
msgid "Notifications"
msgstr "Notificacions"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Dreceres"

#: prefs.js:179
msgid "Search"
msgstr "Cerca"

#: prefs.js:244
msgid "Icon"
msgstr "Icona"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Contingut del porta-retalls"

#: prefs.js:246
msgid "Both"
msgstr "Ambdós"

#: prefs.js:247
msgid "Neither"
msgstr "Cap"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Commuta el menú"

#: prefs.js:260
msgid "Previous entry"
msgstr "Entrada anterior"

#: prefs.js:261
msgid "Next entry"
msgstr "Entrada següent"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Activa les dreceres"

#: prefs.js:291
msgid "Disabled"
msgstr "Desactivat"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Introdueix una drecera"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Nom de classe de la finestra, p. ex. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Trieu de les aplicacions instal·lades"

#: prefs.js:416
msgid "Search applications..."
msgstr "Cerca aplicacions..."

#~ msgid "Refresh Interval (ms)"
#~ msgstr "Interval d’actualització (ms)"

