#: extension.js:113
msgid "Text will be here"
msgstr "Testua hemen agertuko da"

#: extension.js:187
msgid "Type here to search..."
msgstr "Idatzi hemen bilatzeko..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Modu pribatua"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Garbitu historia"

#: extension.js:315
msgid "Settings"
msgstr "Ezarpenak"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Arbela hutsik dago"

#: extension.js:626
msgid "Clear all?"
msgstr "Dena garbitu?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Ziur arbeleko elementu guztiak ezabatu nahi dituzula?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Eragiketa hau ezin da desegin."

#: extension.js:630
msgid "Clear"
msgstr "Garbitu"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Utzi"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Arbeleko historia garbitu da"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Arbeleko historia automatikoki garbitu da"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Arbelean kopiatu da"

#: prefs.js:31
msgid "History Size"
msgstr "Historiaren tamaina"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Aurrebista-tamaina (karaktereak)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Cache-fitxategiaren tamaina max. (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Goiko barrako karaktere kopurua"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Zer erakutsi goiko barran"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Kendu beheranzko gezia goiko barratik"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Soilik finkatutakoak gorde"

#: prefs.js:80
msgid "Show notification on copy"
msgstr "Erakutsi jakinarazpena kopiatzean"

#: prefs.js:84
msgid "Show notification on cycle"
msgstr "Erakutsi jakinarazpena aldatzean"

#: prefs.js:88
msgid "Show confirmation on Clear History"
msgstr "Berrespena erakutsi garbitzean"

#: prefs.js:92
msgid "Remove whitespace around text"
msgstr "Kendu testuaren inguruko zuriuneak"

#: prefs.js:96
msgid "Move item to the top after selection"
msgstr "Eraman gora hautatu ondoren"

#: prefs.js:100
msgid "Keep selected entry after Clear History"
msgstr "Mantendu hautatutako sarrera garbitu ondoren"

#: prefs.js:104
msgid "Show paste buttons"
msgstr "Erakutsi itsatsi botoiak"

#: prefs.js:105
msgid "Adds a paste button to each entry that lets you paste it directly"
msgstr "Itsasteko botoi bat gehitzen du sarrera bakoitzari"

#: prefs.js:109
msgid "Place the pinned section on the bottom"
msgstr "Jarri finkatutakoa behean"

#: prefs.js:110
msgid "Requires restarting the extension"
msgstr "Hedapena berrabiarazi behar da"

#: prefs.js:114
msgid "Clear clipboard history on system reboot"
msgstr "Garbitu historia sistema berrabiaztean"

#: prefs.js:118
msgid "Paste on select"
msgstr "Itsatsi hautatzean"

#: prefs.js:122
msgid "Cache images"
msgstr "Gorde irudiak cachean"

#: prefs.js:127
msgid "Excluded Apps"
msgstr "Baztertutako aplikazioak"

#: prefs.js:128
msgid "Content copied will not be saved while these apps are in focus"
msgstr "Kopiatutako edukia ez da gordeko aplikazio hauek aktibo daudenean"

#: prefs.js:139
msgid "Case-sensitive search"
msgstr "Maiuskula/minuskula bereizten dituen bilaketa"

#: prefs.js:143
msgid "Regular expression matching in search"
msgstr "Adierazpen erregularra bilaketan"

#: prefs.js:156
msgid "Clear clipboard history on interval"
msgstr "Garbitu historia tartean"

#: prefs.js:160
msgid "History clear interval (in minutes)"
msgstr "Garbiketa-tartea (minututan)"

#: prefs.js:172
msgid "UI"
msgstr "Interfazea"

#: prefs.js:173
msgid "Behavior"
msgstr "Portaera"

#: prefs.js:174
msgid "Exclusion"
msgstr "Bazterketa"

#: prefs.js:175
msgid "Limits"
msgstr "Mugak"

#: prefs.js:176
msgid "Topbar"
msgstr "Goiko barra"

#: prefs.js:177
msgid "Notifications"
msgstr "Jakinarazpenak"

#: prefs.js:178
msgid "Shortcuts"
msgstr "Lasterbideak"

#: prefs.js:179
msgid "Search"
msgstr "Bilatu"

#: prefs.js:244
msgid "Icon"
msgstr "Ikonoa"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Arbeleko edukia"

#: prefs.js:246
msgid "Both"
msgstr "Biak"

#: prefs.js:247
msgid "Neither"
msgstr "Bat ere ez"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Txandakatu menua"

#: prefs.js:260
msgid "Previous entry"
msgstr "Aurreko sarrera"

#: prefs.js:261
msgid "Next entry"
msgstr "Hurrengo sarrera"

#: prefs.js:266
msgid "Enable shortcuts"
msgstr "Gaitu lasterbideak"

#: prefs.js:291
msgid "Disabled"
msgstr "Desgaituta"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Sartu lasterbidea"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Leihoaren klasearen izena, adib. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Aukeratu instalatutako aplikazioetatik"

#: prefs.js:416
msgid "Search applications..."
msgstr "Bilatu aplikazioak..."

