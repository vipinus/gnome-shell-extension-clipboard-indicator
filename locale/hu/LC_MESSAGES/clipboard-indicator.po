msgid "Are you sure you want to delete all clipboard items?"
msgstr "Biztosan törölni szeretne minden vágólap-elemet?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Ez a művelet nem vonható vissza."

#: extension.js:630
msgid "Clear"
msgstr "Törlés"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Mégse"

