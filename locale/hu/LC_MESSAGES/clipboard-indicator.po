msgid "Enable shortcuts"
msgstr "Gyorsbillentyűk engedélyezése"

#: prefs.js:291
msgid "Disabled"
msgstr "Letiltva"

#: prefs.js:300
msgid "Enter shortcut"
msgstr "Adjon meg gyorsbillentyűt"

#: prefs.js:387
msgid "Window class name, e.g. \"KeePassXC\""
msgstr "Ablakosztály neve, pl. \"KeePassXC\""

#: prefs.js:399
msgid "Choose from installed applications"
msgstr "Választás a telepített alkalmazásokból"

#: prefs.js:416
msgid "Search applications..."
msgstr "Alkalmazások keresése..."

