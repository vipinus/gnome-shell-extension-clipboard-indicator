#: prefs.js:179
msgid "Search"
msgstr "Keresés"

#: prefs.js:244
msgid "Icon"
msgstr "Ikon"

#: prefs.js:245
msgid "Clipboard Content"
msgstr "Vágólap tartalma"

#: prefs.js:246
msgid "Both"
msgstr "Mindkettő"

#: prefs.js:247
msgid "Neither"
msgstr "Egyik sem"

#: prefs.js:258
msgid "Toggle the menu"
msgstr "Menü ki/be"

#: prefs.js:260
msgid "Previous entry"
msgstr "Előző bejegyzés"

#: prefs.js:261
msgid "Next entry"
msgstr "Következő bejegyzés"

