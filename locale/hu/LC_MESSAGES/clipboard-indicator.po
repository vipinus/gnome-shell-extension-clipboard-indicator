#: extension.js:113
msgid "Text will be here"
msgstr "A szöveg itt fog megjelenni"

#: extension.js:187
msgid "Type here to search..."
msgstr "Írjon be keresési kifejezést..."

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Privát mód"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Előzmények törlése"

#: extension.js:315
msgid "Settings"
msgstr "Beállítások"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "A vágólap üres"

#: extension.js:626
msgid "Clear all?"
msgstr "Mindent töröl?"

