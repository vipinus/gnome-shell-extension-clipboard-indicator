msgstr "Előzmények automatikusan törölve"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "Vágólapra másolva"

#: prefs.js:31
msgid "History Size"
msgstr "Előzmények mérete"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Előnézet mérete (karakter)"

#: prefs.js:49
msgid "Max cache file size (MB)"
msgstr "Max. gyorsítótár-fájlméret (MB)"

#: prefs.js:58
msgid "Number of characters in top bar"
msgstr "Karakterek száma a felső sávban"

#: prefs.js:67
msgid "What to show in top bar"
msgstr "Mit jelenítsen meg a felső sáv"

#: prefs.js:72
msgid "Remove down arrow in top bar"
msgstr "Lefelé nyíl eltávolítása a felső sávból"

#: prefs.js:76
msgid "Cache only pinned items"
msgstr "Csak rögzített elemek gyorsítótárazása"

